generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ads {
  id                String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  created_at        DateTime         @default(now()) @db.Timestamptz(6)
  expires_at        DateTime?        @db.Timestamptz(6)
  title             String
  description       String
  price             Decimal          @db.Decimal(10, 2)
  email             String
  phone_number      String
  token_hash        String
  county            String
  city              String
  status            ad_status        @default(pending)
  plan_type         String           @default("basic")
  is_premium        Boolean          @default(false)
  views             Int              @default(0)
  favorites         Int              @default(0)
  whatsapp_clicks   Int              @default(0)
  rating            Decimal          @default(0) @db.Decimal(3, 2)
  reviews_count     Int              @default(0)
  reviews           Json?            @default("[]")
  slug              String?          @unique
  confirmation_sent Boolean?         @default(false)
  ads_categories    ads_categories[]
  ads_images        ads_images[]
  ads_reviews       ads_reviews[]

  @@index([status, created_at(sort: Desc)], map: "idx_ads_active_latest")
  @@index([county, city], map: "idx_ads_location")
  @@index([is_premium], map: "idx_ads_premium")
  @@index([price], map: "idx_ads_price")
}

model ads_categories {
  ad_id       String     @db.Uuid
  category_id Int
  ads         ads        @relation(fields: [ad_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  categories  categories @relation(fields: [category_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([ad_id, category_id])
  @@index([category_id], map: "idx_ads_categories_category")
}

model ads_images {
  id       String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ad_id    String @db.Uuid
  url      String
  position Int    @default(0)
  ads      ads    @relation(fields: [ad_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([ad_id], map: "idx_ads_images_ad")
}

model ads_reviews {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ad_id      String   @db.Uuid
  author     String?
  rating     Int
  comment    String?
  created_at DateTime @default(now()) @db.Timestamptz(6)
  user_ip    String?
  ads        ads      @relation(fields: [ad_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([ad_id, user_ip], map: "unique_review_per_ip_per_ad")
}

model categories {
  id             Int              @id @default(autoincrement())
  name           String           @unique
  ads_categories ads_categories[]
}

model counties {
  id          Int         @id
  county_code Int         @unique
  name        String
  locations   locations[]
}

model locations {
  id          Int      @id
  siruta      Int      @unique
  county_code Int
  name        String
  county      counties @relation(fields: [county_code], references: [county_code])

  @@index([county_code])
  @@index([name])
}

enum ad_status {
  pending
  active
  expired
  deleted
}
